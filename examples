from env.traffic_env import SmartTrafficEnv
import random

def run_random_agent():
    env = SmartTrafficEnv()
    state = env.reset()

    print("Initial State:")
    print(state)
    print("-" * 50)

    total_reward = 0

    for step in range(200):
        # Random action: 0 (keep signal) or 1 (switch signal)
        action = random.choice([0, 1])

        next_state, reward, done = env.step(action)

        total_reward += reward

        print(f"Step: {step + 1}")
        print(f"Action Taken: {'Switch Signal' if action == 1 else 'Keep Signal'}")
        print(f"State: {next_state}")
        print(f"Reward: {reward}")
        print("-" * 50)

        if done:
            break

    print("Episode Finished")
    print(f"Total Reward: {total_reward}")


if __name__ == "__main__":
    run_random_agent()
