import random

class SmartTrafficEnv:
    def __init__(self, max_steps=200):
        self.max_steps = max_steps
        self.reset()

    def reset(self):
        self.north_queue = random.randint(5, 15)
        self.south_queue = random.randint(5, 15)
        self.east_queue = random.randint(5, 15)
        self.west_queue = random.randint(5, 15)

        self.current_signal = 0  # 0: NS green, 1: EW green
        self.time_elapsed = 0

        return self.state()

    def state(self):
        return {
            "north_queue": self.north_queue,
            "south_queue": self.south_queue,
            "east_queue": self.east_queue,
            "west_queue": self.west_queue,
            "current_signal": self.current_signal,
            "time_elapsed": self.time_elapsed
        }

    def step(self, action):
        prev_total = self.total_queue()

        # Apply action
        if action == 1:
            self.current_signal = 1 - self.current_signal

        # Traffic flow logic
        self._process_traffic()

        # New vehicles arrive
        self._generate_traffic()

        self.time_elapsed += 1

        # Calculate reward
        new_total = self.total_queue()
        reward = -1 - 0.5 * new_total

        if new_total < prev_total:
            reward += 10

        done = self.time_elapsed >= self.max_steps

        return self.state(), reward, done

    def total_queue(self):
        return (
            self.north_queue +
            self.south_queue +
            self.east_queue +
            self.west_queue
        )

    def _process_traffic(self):
        flow = random.randint(2, 5)

        if self.current_signal == 0:
            self.north_queue = max(0, self.north_queue - flow)
            self.south_queue = max(0, self.south_queue - flow)
        else:
            self.east_queue = max(0, self.east_queue - flow)
            self.west_queue = max(0, self.west_queue - flow)

    def _generate_traffic(self):
        self.north_queue += random.randint(0, 3)
        self.south_queue += random.randint(0, 3)
        self.east_queue += random.randint(0, 3)
        self.west_queue += random.randint(0, 3)
